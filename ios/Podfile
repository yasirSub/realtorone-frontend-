# RealtorOne — required for Flutter iOS native plugins (Firebase, Google Sign-In, etc.)
platform :ios, '15.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run `flutter pub get` in the project root first."
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      raw = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
      defs =
        if raw.nil?
          ['$(inherited)']
        elsif raw.is_a?(String)
          ['$(inherited)', raw]
        else
          raw.dup.tap { |d| d.unshift('$(inherited)') unless d.include?('$(inherited)') }
        end
      %w[
        PERMISSION_CAMERA=1
        PERMISSION_MICROPHONE=1
        PERMISSION_PHOTOS=1
        PERMISSION_NOTIFICATIONS=1
      ].each do |macro|
        defs << macro unless defs.include?(macro)
      end
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
    end
  end
end
